# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Email (Gmail SMTP) ────────────────────────────────────
# 1. Use your Gmail address below
# 2. Enable 2-Factor Auth on your Google Account
# 3. Go to Google Account → Security → App Passwords → generate one
# 4. Paste that 16-char password as GMAIL_PASS
GMAIL_USER=your.email@gmail.com
GMAIL_PASS=your_16char_app_password

# Email where contact form submissions arrive
CONTACT_RECEIVER=hello@mayanksharma.in

# ─── Site ──────────────────────────────────────────────────
SITE_URL=http://localhost:3000
